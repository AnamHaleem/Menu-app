# Backend runtime
PORT=3001
NODE_ENV=development

# Required database config (Railway production can use DATABASE_URL from Postgres service)
DATABASE_URL=postgresql://postgres:password@localhost:5432/menu_db

# Optional comma-separated frontend origins for CORS
# Example: https://your-app.vercel.app,https://preview-url.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional auth (if absent, Clerk middleware is disabled)
CLERK_SECRET_KEY=

# Integrations
OPENWEATHER_API_KEY=
RESEND_API_KEY=
